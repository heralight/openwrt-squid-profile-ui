{
    "luci-app-squid-profiles": {
        "description": "Permissions for Squid Profiles UI",
        "read": {
            "uci": [ "squid_profiles", "dhcp", "network" ],
            "file": {
                "/etc/squid": [ "list" ],
                "/etc/squid/*": [ "list", "read", "stat" ]
            },
            "ubus": {
                "file": [ "list", "read", "stat" ]
            }
        },
        "write": {
            "uci": [ "squid_profiles" ],
            "file": {
                "/usr/libexec/squid-profiles": [ "exec" ]
            },
            "ubus": {
                "file": [ "exec" ]
            }
        }
    }
}
