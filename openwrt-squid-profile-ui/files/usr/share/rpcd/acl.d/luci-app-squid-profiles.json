{
    "luci-app-squid-profiles": {
        "description": "Permissions for Squid Profiles UI",
        "read": {
            "uci": [ "squid_profiles", "dhcp", "network" ],
            "file": {
                "path": [ "/etc/squid" ]
            }
        },
        "write": {
            "uci": [ "squid_profiles" ],
            "file": {
                "path": [ "/etc/squid" ]
            },
            "command": [ "/usr/libexec/squid-profiles", "/usr/sbin/squid" ]
        }
    }
}
