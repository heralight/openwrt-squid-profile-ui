#!/bin/sh

set -eu

SQUID_DIR="${SQUID_DIR:-/etc/squid}"
SQUID_CONF="${SQUID_CONF:-$SQUID_DIR/squid.conf}"
DOMAINS_DIR="$SQUID_DIR/domains"
MAPS_DIR="$SQUID_DIR/maps"
MIME_CONF="$SQUID_DIR/mime.conf"
CONFIG="${CONFIG:-squid_profiles}"
TMP_CONF="/tmp/squid-profiles.squid.conf"
FINAL_CONF="/tmp/squid-profiles.squid.final.conf"
FINAL_MAP="/tmp/squid-profiles.10-profiles.final.conf"
STAGE_DIR="/tmp/squid-profiles.$$"
STAGE_DOMAINS="$STAGE_DIR/domains"
STAGE_MAPS="$STAGE_DIR/maps"
STAGE_EXPECTED_DOMAINS="$STAGE_DIR/domains.expected"
STAGE_EXPECTED_MAPS="$STAGE_DIR/maps.expected"

log() { printf '%s\n' "$*"; }
fail() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
need_cmd() { command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"; }

cleanup_stage() {
	rm -rf "$STAGE_DIR"
}

trap cleanup_stage EXIT HUP INT TERM

unique_backup_path() {
	base="$1.$(date +%Y%m%d-%H%M%S).bak"
	[ -e "$base" ] || { printf '%s\n' "$base"; return; }
	i=1
	while [ -e "$base.$i" ]; do i=$((i + 1)); done
	printf '%s\n' "$base.$i"
}

write_skeleton() {
	target="$1"
	include_path="${2:-/etc/squid/maps/10-profiles.conf}"
	cat > "$target" <<'EOSQUID'
# Generated by luci-app-squid-profiles.
# Manual changes may be replaced by the LuCI application.

visible_hostname openwrt-squid-profiles
http_port 3128

acl SSL_ports port 443
acl Safe_ports port 80
acl Safe_ports port 443
acl CONNECT method CONNECT

http_access deny !Safe_ports
http_access deny CONNECT !SSL_ports

include INCLUDE_PATH

http_access deny all

cache deny all
cache_mem 8 MB
maximum_object_size 0 KB

access_log none
cache_log /dev/null
logfile_rotate 3

refresh_pattern ^ftp:       1440    20%     10080
refresh_pattern ^gopher:    1440    0%      1440
refresh_pattern -i (/cgi-bin/|\?) 0 0%      0
refresh_pattern .           0       20%     4320
EOSQUID
	sed -i "s|INCLUDE_PATH|$include_path|" "$target"
}

write_mime_conf() {
	if [ ! -f "$MIME_CONF" ]; then
		printf '.* application/octet-stream - - -\n' > "$MIME_CONF"
		log "Created Squid MIME table: $MIME_CONF"
	fi
}

init_tree() {
	mkdir -p "$SQUID_DIR" "$DOMAINS_DIR" "$MAPS_DIR"
	log "Ensured directory: $SQUID_DIR"
	log "Ensured directory: $DOMAINS_DIR"
	log "Ensured directory: $MAPS_DIR"

	if [ ! -f "$MAPS_DIR/10-profiles.conf" ]; then
		: > "$MAPS_DIR/10-profiles.conf"
		log "Created empty profile map: $MAPS_DIR/10-profiles.conf"
	fi

	if [ -f "$SQUID_CONF" ]; then
		if grep -q "Generated by luci-app-squid-profiles" "$SQUID_CONF"; then
			log "Existing plugin-managed Squid configuration kept: $SQUID_CONF"
		else
			backup="$(unique_backup_path "$SQUID_CONF")"
			mv "$SQUID_CONF" "$backup"
			log "Backed up existing Squid configuration: $backup"
		fi
	fi

	write_mime_conf

	if [ ! -f "$SQUID_CONF" ]; then
		write_skeleton "$SQUID_CONF"
		log "Created Squid skeleton: $SQUID_CONF"
	fi
}

backup_current_config() {
	if [ -f "$SQUID_CONF" ]; then
		backup="$(unique_backup_path "$SQUID_CONF")"
		cp "$SQUID_CONF" "$backup"
		log "Backed up current Squid configuration before modification: $backup"
	fi
}

init_stage() {
	mkdir -p "$STAGE_DOMAINS" "$STAGE_MAPS"
	: > "$STAGE_EXPECTED_DOMAINS"
	: > "$STAGE_EXPECTED_MAPS"
}

backup_and_replace_if_changed() {
	source="$1"
	target="$2"
	label="$3"
	if [ -f "$target" ] && cmp -s "$target" "$source"; then
		rm -f "$source"
		return 0
	fi
	if [ -e "$target" ]; then
		backup="$(unique_backup_path "$target")"
		cp "$target" "$backup"
		log "Backed up changed $label: $backup"
	fi
	cp "$source" "$target"
	rm -f "$source"
	log "Updated $label: $target"
}

normalize_name() { printf '%s' "$1" | tr -c 'A-Za-z0-9_' '_' | sed 's/^_*//;s/_*$//'; }

normalize_domain() {
	domain="$(printf '%s' "$1" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
	case "$domain" in \*.*) domain=".${domain#*.}" ;; esac
	printf '%s\n' "$domain"
}

is_domain() {
	case "$1" in ""|*"/"*|*" "*|*".."*|*.) return 1 ;; esac
	domain="$(normalize_domain "$1")"
	case "$domain" in .*) domain="${domain#.}" ;; esac
	printf '%s\n' "$domain" | grep -Eq '^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?(\.[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?)+'
}

is_ipv4_cidr() {
	addr="${1%/*}"; prefix="${1#*/}"
	[ "$addr" != "$1" ] || return 1
	case "$prefix" in ""|*[!0-9]*) return 1 ;; esac
	[ "$prefix" -ge 0 ] 2>/dev/null && [ "$prefix" -le 32 ] || return 1
	old_ifs="$IFS"; IFS=.; set -- $addr; IFS="$old_ifs"
	[ "$#" -eq 4 ] || return 1
	for octet in "$@"; do
		case "$octet" in ""|*[!0-9]*) return 1 ;; esac
		[ "$octet" -ge 0 ] 2>/dev/null && [ "$octet" -le 255 ] || return 1
	done
	return 0
}

normalize_ipv4_cidr() {
	cidr="$1"
	is_ipv4_cidr "$cidr" || { printf '%s\n' "$cidr"; return; }
	addr="${cidr%/*}"
	prefix="${cidr#*/}"
	old_ifs="$IFS"; IFS=.; set -- $addr; IFS="$old_ifs"
	ip=$(( ($1 << 24) + ($2 << 16) + ($3 << 8) + $4 ))
	if [ "$prefix" -eq 0 ]; then
		mask=0
	else
		mask=$(( (0xffffffff << (32 - prefix)) & 0xffffffff ))
	fi
	net=$(( ip & mask ))
	printf '%d.%d.%d.%d/%d\n' \
		$(( (net >> 24) & 255 )) \
		$(( (net >> 16) & 255 )) \
		$(( (net >> 8) & 255 )) \
		$(( net & 255 )) \
		"$prefix"
}

validate_domain_list() {
	list="$1"; label="$2"
	for domain in $list; do is_domain "$domain" || fail "invalid domain in $label: $domain"; done
	dupes="$(printf '%s\n' $list 2>/dev/null | sort | uniq -d | tr '\n' ' ')"
	[ -z "$dupes" ] || fail "duplicate domain in $label: $dupes"
}

collect_profile_domains() {
	section="$1"
	mode="$(uci -q get "$CONFIG.$section.edit_mode" || printf 'lists')"
	if [ "$mode" = "text" ]; then
		allow="$(uci -q get "$CONFIG.$section.allow_domain" || true)"
		deny="$(uci -q get "$CONFIG.$section.deny_domain" || true)"
		if [ -n "$allow" ] || [ -n "$deny" ]; then
			printf '%s\n%s\n' "$allow" "$deny"
			return 0
		fi

		allow=""
		deny=""
		raw="$(uci -q get "$CONFIG.$section.raw_rules" || true)"
		while IFS= read -r line; do
			line="$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
			case "$line" in
				""|\#*) continue ;;
				allow\ *)
					domain="${line#allow }"
					domain="$(normalize_domain "$domain")"
					is_domain "$domain" || fail "invalid domain in profile $section raw rules: $domain"
					allow="$allow $domain"
				;;
				deny\ *)
					domain="${line#deny }"
					domain="$(normalize_domain "$domain")"
					is_domain "$domain" || fail "invalid domain in profile $section raw rules: $domain"
					deny="$deny $domain"
				;;
				*)
					fail "invalid rule syntax in profile $section raw rules: $line"
				;;
			esac
		done <<EOF
$raw
EOF
		printf '%s\n%s\n' "$allow" "$deny"
		return 0
	fi

	allow="$(uci -q get "$CONFIG.$section.allow_domain" || true)"
	deny="$(uci -q get "$CONFIG.$section.deny_domain" || true)"
	printf '%s\n%s\n' "$allow" "$deny"
}

validate_uci() {
	need_cmd uci
	for section in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=profile$/\1/p"); do
		name="$(uci -q get "$CONFIG.$section.name" || true)"
		[ -n "$name" ] || fail "profile $section has no name"
		profile_domains="$(collect_profile_domains "$section")"
		allow="$(printf '%s\n' "$profile_domains" | sed -n '1p')"
		deny="$(printf '%s\n' "$profile_domains" | sed -n '2p')"
		validate_domain_list "$allow" "profile $name allow list"
		validate_domain_list "$deny" "profile $name deny list"
		conflicts="$(for d in $allow; do for e in $deny; do [ "$d" = "$e" ] && printf '%s ' "$d"; done; done || true)"
		[ -z "$conflicts" ] || fail "domain present in allow and deny lists for profile $name: $conflicts"
	done
	for section in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=network$/\1/p"); do
		cidr="$(uci -q get "$CONFIG.$section.cidr" || uci -q get "$CONFIG.$section.subnet" || true)"
		vlan="$(uci -q get "$CONFIG.$section.vlan" || true)"
		is_ipv4_cidr "$cidr" || fail "invalid IPv4 CIDR in network $section: $cidr"
		[ -n "$vlan" ] || fail "network $cidr has no VLAN/LAN label"
		profiles="$(uci -q get "$CONFIG.$section.profile" || true)"
		for profile in $profiles; do
			[ -n "$profile" ] || fail "network $cidr has an empty profile entry"
		done
	done
}

ensure_core_section() {
	need_cmd uci
	if ! uci -q get "$CONFIG.core" >/dev/null 2>&1; then
		uci batch <<EOF
set $CONFIG.core=globals
set $CONFIG.core.enabled='1'
commit $CONFIG
EOF
	fi
}

set_enabled_state() {
	state="$1"
	case "$state" in
		0|1) ;;
		*) fail "invalid enabled state: $state" ;;
	esac
	ensure_core_section
	uci set "$CONFIG.core.enabled=$state"
	uci commit "$CONFIG"
	log "Set $CONFIG.core.enabled to $state"
}

prune_config() {
	need_cmd uci

	for section in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=vm$/\1/p"); do
		profiles="$(uci -q get "$CONFIG.$section.profile" || true)"
		if [ -z "$profiles" ]; then
			uci delete "$CONFIG.$section"
			log "Pruned unmapped device section: $section"
		fi
	done

	for section in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=network$/\1/p"); do
		source="$(uci -q get "$CONFIG.$section.source" || printf 'custom')"
		profiles="$(uci -q get "$CONFIG.$section.profile" || true)"
		if [ "$source" = "system" ] && [ -z "$profiles" ]; then
			uci delete "$CONFIG.$section"
			log "Pruned unmapped system network section: $section"
		fi
	done

	uci commit "$CONFIG"
}

write_domain_file() {
	file="$1"; shift; : > "$file"
	for domain in "$@"; do [ -n "$domain" ] && printf '%s\n' "$domain" >> "$file"; done
}

write_map_file() {
	target="$1"
	domains_dir="$2"
	: > "$target"
	for net in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=network$/\1/p"); do
		cidr="$(uci -q get "$CONFIG.$net.cidr" || uci -q get "$CONFIG.$net.subnet" || true)"
		profiles="$(uci -q get "$CONFIG.$net.profile" || true)"
		[ -n "$profiles" ] || continue
		[ -n "$cidr" ] && printf 'acl squid_profiles_net_%s src %s\n' "$(normalize_name "$net")" "$(normalize_ipv4_cidr "$cidr")" >> "$target"
	done
	for section in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=profile$/\1/p"); do
		name="$(uci -q get "$CONFIG.$section.name" || printf '%s' "$section")"
		id="$(normalize_name "$name")"
		[ -s "$domains_dir/$id.allow.txt" ] && printf 'acl profile_%s_allow dstdomain "%s"\n' "$id" "$domains_dir/$id.allow.txt" >> "$target"
		[ -s "$domains_dir/$id.deny.txt" ] && printf 'acl profile_%s_deny dstdomain "%s"\n' "$id" "$domains_dir/$id.deny.txt" >> "$target"
	done
	for net in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=network$/\1/p"); do
		cidr="$(uci -q get "$CONFIG.$net.cidr" || uci -q get "$CONFIG.$net.subnet" || true)"
		profiles="$(uci -q get "$CONFIG.$net.profile" || true)"
		[ -n "$cidr" ] || continue
		net_id="$(normalize_name "$net")"
		for profile in $profiles; do
			id="$(normalize_name "$profile")"
			[ -s "$domains_dir/$id.deny.txt" ] && printf 'http_access deny squid_profiles_net_%s profile_%s_deny\n' "$net_id" "$id" >> "$target"
			[ -s "$domains_dir/$id.allow.txt" ] && printf 'http_access allow squid_profiles_net_%s profile_%s_allow\n' "$net_id" "$id" >> "$target"
		done
	done
	for vm in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=vm$/\1/p"); do
		ip="$(uci -q get "$CONFIG.$vm.ip" || printf '%s' "$vm")"; profiles="$(uci -q get "$CONFIG.$vm.profile" || true)"
		[ -n "$profiles" ] || continue
		printf 'acl device_%s src %s\n' "$(normalize_name "$ip")" "$ip" >> "$target"
		for profile in $profiles; do
			id="$(normalize_name "$profile")"
			[ -s "$domains_dir/$id.deny.txt" ] && printf 'http_access deny device_%s profile_%s_deny\n' "$(normalize_name "$ip")" "$id" >> "$target"
			[ -s "$domains_dir/$id.allow.txt" ] && printf 'http_access allow device_%s profile_%s_allow\n' "$(normalize_name "$ip")" "$id" >> "$target"
		done
	done
}

emit_profile_files() {
	init_stage
	for section in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=profile$/\1/p"); do
		name="$(uci -q get "$CONFIG.$section.name" || printf '%s' "$section")"
		id="$(normalize_name "$name")"
		profile_domains="$(collect_profile_domains "$section")"
		allow="$(printf '%s\n' "$profile_domains" | sed -n '1p')"
		deny="$(printf '%s\n' "$profile_domains" | sed -n '2p')"
		write_domain_file "$STAGE_DOMAINS/$id.allow.txt" $allow
		printf '%s\n' "$id.allow.txt" >> "$STAGE_EXPECTED_DOMAINS"
		write_domain_file "$STAGE_DOMAINS/$id.deny.txt" $deny
		printf '%s\n' "$id.deny.txt" >> "$STAGE_EXPECTED_DOMAINS"
	done
	write_map_file "$STAGE_MAPS/10-profiles.conf" "$STAGE_DOMAINS"
	printf '%s\n' "10-profiles.conf" >> "$STAGE_EXPECTED_MAPS"
	log "Prepared staged domain files: $STAGE_DOMAINS"
	log "Prepared staged map file: $STAGE_MAPS/10-profiles.conf"
}

sync_profile_files() {
	for file in "$STAGE_DOMAINS"/*.txt; do
		[ -e "$file" ] || continue
		backup_and_replace_if_changed "$file" "$DOMAINS_DIR/$(basename "$file")" "domain file"
	done
	for file in "$DOMAINS_DIR"/*.txt; do
		[ -e "$file" ] || continue
		grep -Fxq "$(basename "$file")" "$STAGE_EXPECTED_DOMAINS" 2>/dev/null && continue
		backup="$(unique_backup_path "$file")"
		cp "$file" "$backup"
		rm -f "$file"
		log "Backed up removed domain file: $backup"
	done
	write_map_file "$FINAL_MAP" "$DOMAINS_DIR"
	backup_and_replace_if_changed "$FINAL_MAP" "$MAPS_DIR/10-profiles.conf" "map file"
	log "Updated domain files: $DOMAINS_DIR"
	log "Updated map file: $MAPS_DIR/10-profiles.conf"
}

validate_squid() {
	need_cmd squid
	config="$1"
	# Keep the literal validation command visible for reviewers: squid -k parse
	squid -f "$config" -k parse
}

apply_config() {
	init_tree
	validate_uci
	emit_profile_files
	write_skeleton "$TMP_CONF" "$STAGE_MAPS/10-profiles.conf"
	validate_squid "$TMP_CONF"
	sync_profile_files
	write_skeleton "$FINAL_CONF" "$MAPS_DIR/10-profiles.conf"
	validate_squid "$FINAL_CONF"
	backup_and_replace_if_changed "$FINAL_CONF" "$SQUID_CONF" "Squid configuration"
	if squid -f "$SQUID_CONF" -k reconfigure; then
		log "Reconfigured running Squid instance"
	else
		log "Squid was not running; starting Squid"
		squid -f "$SQUID_CONF"
	fi
	log "Applied Squid configuration: $SQUID_CONF"
}

case "${1:-}" in
	init) init_tree ;;
	generate) init_tree; validate_uci; emit_profile_files; write_skeleton "$SQUID_CONF" ;;
	validate) init_tree; validate_uci; emit_profile_files; write_skeleton "$TMP_CONF"; validate_squid "$TMP_CONF" ;;
	apply) apply_config ;;
	enable) set_enabled_state 1 ;;
	disable) set_enabled_state 0 ;;
	prune) prune_config ;;
	*) printf 'Usage: %s init|generate|validate|apply|enable|disable|prune\n' "$0"; exit 2 ;;
esac
