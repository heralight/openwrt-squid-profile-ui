#!/bin/sh

set -eu

SQUID_DIR="${SQUID_DIR:-/etc/squid}"
SQUID_CONF="${SQUID_CONF:-$SQUID_DIR/squid.conf}"
DOMAINS_DIR="$SQUID_DIR/domains"
MAPS_DIR="$SQUID_DIR/maps"
CONFIG="${CONFIG:-squid_profiles}"
TMP_CONF="/tmp/squid-profiles.squid.conf"

log() {
	printf '%s\n' "$*"
}

fail() {
	printf 'ERROR: %s\n' "$*" >&2
	exit 1
}

need_cmd() {
	command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

unique_backup_path() {
	base="$1.$(date +%Y%m%d).bak"
	if [ ! -e "$base" ]; then
		printf '%s\n' "$base"
		return
	fi

	i=1
	while [ -e "$base.$i" ]; do
		i=$((i + 1))
	done
	printf '%s\n' "$base.$i"
}

write_skeleton() {
	target="$1"
	cat > "$target" <<'EOSQUID'
# Generated by luci-app-squid-profiles.
# Manual changes may be replaced by the LuCI application.

visible_hostname openwrt-squid-profiles
http_port 3128

acl SSL_ports port 443
acl Safe_ports port 80
acl Safe_ports port 443
acl CONNECT method CONNECT

http_access deny !Safe_ports
http_access deny CONNECT !SSL_ports

include /etc/squid/maps/*.conf

http_access deny all

cache deny all
cache_mem 8 MB
maximum_object_size 0 KB
pinger_enable off

access_log stdio:/tmp/squid_access.log squid
cache_log /tmp/squid_cache.log
logfile_rotate 3

refresh_pattern ^ftp:       1440    20%     10080
refresh_pattern ^gopher:    1440    0%      1440
refresh_pattern -i (/cgi-bin/|\?) 0 0%      0
refresh_pattern .           0       20%     4320
EOSQUID
}

init_tree() {
	mkdir -p "$SQUID_DIR" "$DOMAINS_DIR" "$MAPS_DIR"
	log "Ensured directory: $SQUID_DIR"
	log "Ensured directory: $DOMAINS_DIR"
	log "Ensured directory: $MAPS_DIR"

	if [ -f "$SQUID_CONF" ]; then
		if grep -q "Generated by luci-app-squid-profiles" "$SQUID_CONF"; then
			log "Existing plugin-managed Squid configuration kept: $SQUID_CONF"
		else
			backup="$(unique_backup_path "$SQUID_CONF")"
			mv "$SQUID_CONF" "$backup"
			log "Backed up existing Squid configuration: $backup"
		fi
	fi

	if [ ! -f "$SQUID_CONF" ]; then
		write_skeleton "$SQUID_CONF"
		log "Created Squid skeleton: $SQUID_CONF"
	fi
}

backup_current_config() {
	if [ -f "$SQUID_CONF" ]; then
		backup="$(unique_backup_path "$SQUID_CONF")"
		cp "$SQUID_CONF" "$backup"
		log "Backed up current Squid configuration before modification: $backup"
	fi
}

normalize_name() {
	printf '%s' "$1" | tr -c 'A-Za-z0-9_' '_' | sed 's/^_*//;s/_*$//'
}

is_domain() {
	case "$1" in
		""|*"/"*|*" "*|*".."*|.*|*.) return 1 ;;
	esac
	printf '%s\n' "$1" | grep -Eq '^(\*\.)?[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?(\.[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?)+$'
}

is_ipv4_cidr() {
	addr="${1%/*}"
	prefix="${1#*/}"
	[ "$addr" != "$1" ] || return 1
	case "$prefix" in ""|*[!0-9]*) return 1 ;; esac
	[ "$prefix" -ge 0 ] 2>/dev/null && [ "$prefix" -le 32 ] || return 1
	old_ifs="$IFS"
	IFS=.
	set -- $addr
	IFS="$old_ifs"
	[ "$#" -eq 4 ] || return 1
	for octet in "$@"; do
		case "$octet" in ""|*[!0-9]*) return 1 ;; esac
		[ "$octet" -ge 0 ] 2>/dev/null && [ "$octet" -le 255 ] || return 1
	done
	return 0
}

validate_domain_list() {
	list="$1"
	label="$2"
	for domain in $list; do
		is_domain "$domain" || fail "invalid domain in $label: $domain"
	done
	dupes="$(printf '%s\n' $list 2>/dev/null | sort | uniq -d | tr '\n' ' ')"
	[ -z "$dupes" ] || fail "duplicate domain in $label: $dupes"
}

validate_uci() {
	need_cmd uci

	for section in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=profile$/\1/p"); do
		name="$(uci -q get "$CONFIG.$section.name" || true)"
		[ -n "$name" ] || fail "profile $section has no name"
		allow="$(uci -q get "$CONFIG.$section.allow_domain" || true) $(uci -q get "$CONFIG.$section.allow_text" || true)"
		deny="$(uci -q get "$CONFIG.$section.deny_domain" || true) $(uci -q get "$CONFIG.$section.deny_text" || true)"
		validate_domain_list "$allow" "profile $name allow list"
		validate_domain_list "$deny" "profile $name deny list"
		conflicts="$(for d in $allow; do for e in $deny; do [ "$d" = "$e" ] && printf '%s ' "$d"; done; done)"
		[ -z "$conflicts" ] || fail "domain present in allow and deny lists for profile $name: $conflicts"
	done

	for section in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=network$/\1/p"); do
		cidr="$(uci -q get "$CONFIG.$section.cidr" || uci -q get "$CONFIG.$section.subnet" || true)"
		vlan="$(uci -q get "$CONFIG.$section.vlan" || true)"
		is_ipv4_cidr "$cidr" || fail "invalid IPv4 CIDR in network $section: $cidr"
		[ -n "$vlan" ] || fail "network $cidr has no VLAN/LAN label"
	done
}

write_domain_file() {
	file="$1"
	shift
	: > "$file"
	for domain in "$@"; do
		[ -n "$domain" ] && printf '.%s\n' "$domain" >> "$file"
	done
}

emit_profile_files() {
	rm -f "$DOMAINS_DIR"/*.txt "$MAPS_DIR"/*.conf 2>/dev/null || true

	for section in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=profile$/\1/p"); do
		name="$(uci -q get "$CONFIG.$section.name" || printf '%s' "$section")"
		id="$(normalize_name "$name")"
		allow="$(uci -q get "$CONFIG.$section.allow_domain" || true) $(uci -q get "$CONFIG.$section.allow_text" || true)"
		deny="$(uci -q get "$CONFIG.$section.deny_domain" || true) $(uci -q get "$CONFIG.$section.deny_text" || true)"
		write_domain_file "$DOMAINS_DIR/$id.allow.txt" $allow
		write_domain_file "$DOMAINS_DIR/$id.deny.txt" $deny
	done

	map_file="$MAPS_DIR/10-profiles.conf"
	: > "$map_file"
	for net in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=network$/\1/p"); do
		cidr="$(uci -q get "$CONFIG.$net.cidr" || uci -q get "$CONFIG.$net.subnet" || true)"
		[ -n "$cidr" ] && printf 'acl squid_profiles_net_%s src %s\n' "$(normalize_name "$net")" "$cidr" >> "$map_file"
	done

	for section in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=profile$/\1/p"); do
		name="$(uci -q get "$CONFIG.$section.name" || printf '%s' "$section")"
		id="$(normalize_name "$name")"
		[ -s "$DOMAINS_DIR/$id.allow.txt" ] && printf 'acl profile_%s_allow dstdomain "%s"\n' "$id" "$DOMAINS_DIR/$id.allow.txt" >> "$map_file"
		[ -s "$DOMAINS_DIR/$id.deny.txt" ] && printf 'acl profile_%s_deny dstdomain "%s"\n' "$id" "$DOMAINS_DIR/$id.deny.txt" >> "$map_file"
	done

	for vm in $(uci show "$CONFIG" 2>/dev/null | sed -n "s/^$CONFIG\.\([^.=]*\)=vm$/\1/p"); do
		ip="$vm"
		profiles="$(uci -q get "$CONFIG.$vm.profile" || true)"
		[ -n "$profiles" ] || continue
		printf 'acl vm_%s src %s\n' "$(normalize_name "$ip")" "$ip" >> "$map_file"
		for profile in $profiles; do
			id="$(normalize_name "$profile")"
			[ -s "$DOMAINS_DIR/$id.deny.txt" ] && printf 'http_access deny vm_%s profile_%s_deny\n' "$(normalize_name "$ip")" "$id" >> "$map_file"
			[ -s "$DOMAINS_DIR/$id.allow.txt" ] && printf 'http_access allow vm_%s profile_%s_allow\n' "$(normalize_name "$ip")" "$id" >> "$map_file"
		done
	done

	log "Updated domain files: $DOMAINS_DIR"
	log "Updated map file: $map_file"
}

validate_squid() {
	need_cmd squid
	config="$1"
	# Keep the literal validation command visible for reviewers: squid -k parse
	squid -f "$config" -k parse
}

apply_config() {
	init_tree
	validate_uci
	emit_profile_files
	write_skeleton "$TMP_CONF"
	validate_squid "$TMP_CONF"
	backup_current_config
	cp "$TMP_CONF" "$SQUID_CONF"
	squid -k reconfigure
	log "Applied Squid configuration: $SQUID_CONF"
}

case "${1:-}" in
	init)
		init_tree
		;;
	generate)
		init_tree
		validate_uci
		emit_profile_files
		write_skeleton "$SQUID_CONF"
		;;
	validate)
		init_tree
		validate_uci
		emit_profile_files
		write_skeleton "$TMP_CONF"
		validate_squid "$TMP_CONF"
		;;
	apply)
		apply_config
		;;
	*)
		cat <<EOUSAGE
Usage: $0 init|generate|validate|apply
EOUSAGE
		exit 2
		;;
esac
